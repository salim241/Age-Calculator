<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="360dp"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="@drawable/hero_card_bg">

    <ImageView
        android:id="@+id/imgShareIcon"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/outline_celebration_24"
        app:tint="@android:color/white"/>

    <TextView
        android:id="@+id/txtShareTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Age Calculator"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:textSize="26sp"/>

    <TextView
        android:id="@+id/txtShareYears"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="21"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:textSize="72sp"/>

    <TextView
        android:id="@+id/txtShareYearsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="YEARS"
        android:textColor="#DCEBFF"
        android:textStyle="bold"
        android:textSize="18sp"/>

    <TextView
        android:id="@+id/txtShareSummary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="21 Years • 10 Months • 19 Days"
        android:textColor="@android:color/white"
        android:textSize="18sp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="24dp"
        android:background="#55FFFFFF"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Next Birthday"
        android:textColor="#DCEBFF"
        android:textStyle="bold"
        android:textSize="16sp"/>

    <TextView
        android:id="@+id/txtShareBirthday"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="30 August 2026"
        android:textColor="@android:color/white"
        android:textSize="20sp"/>

    <TextView
        android:id="@+id/txtShareCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="42 days remaining"
        android:textColor="#DCEBFF"
        android:textSize="16sp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Generated using Age Calculator"
        android:textColor="#BFD7FF"
        android:textSize="14sp"/>

</LinearLayout>